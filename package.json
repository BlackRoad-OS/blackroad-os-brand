{
  "name": "blackroad-os-brand",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "tokens": "tsx build/generate.ts",
    "storybook": "storybook dev -p 6006",
    "build:docs": "storybook build -o .out",
    "lint": "pnpm run lint:ts && pnpm run lint:css",
    "lint:svg": "svgo -q -f logo --config=svgo.config.js",
    "lint:tokens": "tsx scripts/validate-tokens.ts",
    "lint:ts": "eslint \"src/**/*.{ts,tsx}\"",
    "lint:css": "stylelint \"css/**/*.css\"",
    "format": "prettier --write \"{src,stories,build,storybook,tokens}/**/*.{ts,tsx,js,json,mdx}\" README.md",
    "postbuild": "tsx scripts/postbuild.ts",
    "ci": "pnpm run tokens && pnpm run lint && pnpm run lint:svg && pnpm run lint:tokens && pnpm run build:docs"
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^8.1.10",
    "@storybook/addon-interactions": "^8.1.10",
    "@storybook/addon-links": "^8.1.10",
    "@storybook/blocks": "^8.1.10",
    "@storybook/react": "^8.1.10",
    "@storybook/react-vite": "^8.1.10",
    "@storybook/theming": "^8.1.10",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "autoprefixer": "^10.4.20",
    "@types/node": "^20.12.12",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-react": "^7.34.1",
    "prettier": "^3.2.5",
    "postcss": "^8.4.47",
    "stylelint": "^16.6.1",
    "stylelint-config-standard": "^36.0.0",
    "storybook": "^8.1.10",
    "svgo": "^3.3.2",
    "tailwindcss": "^3.4.13",
    "tsup": "^8.2.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.5"
  }
}
